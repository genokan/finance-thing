{
  "name": "finance-thing",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "PORT=3001 npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client && npm run build -w server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "concurrently -s all -n typecheck,test -c blue,green \"npm:typecheck\" \"npm:test\"",
    "seed": "npm run db:seed -w server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "hono": "^4.12.25"
  }
}
