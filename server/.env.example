DATABASE_URL=postgresql://user:password@localhost:5432/finance_thing
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/finance_thing_test
JWT_SECRET=change_me_32_chars_minimum_secret
JWT_REFRESH_SECRET=change_me_different_32_chars_secret
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Required for OAuth banks in production. Must exactly match an Allowed redirect URI
# in the Plaid dashboard, e.g. https://finance.yourdomain/ (or http://localhost:3000/ in dev).
PLAID_REDIRECT_URI=
FINNHUB_API_KEY=
ENCRYPTION_KEY=change_me_64_hex_chars_random_key_here_do_not_use_in_production00
PORT=3000
NODE_ENV=development
# Logging (Pino). LOG_LEVEL: trace|debug|info|warn|error. Default debug in dev, info in prod.
LOG_LEVEL=debug
# HTTP access logging is off by default; set true to log every request.
HTTP_ACCESS_LOG=false
